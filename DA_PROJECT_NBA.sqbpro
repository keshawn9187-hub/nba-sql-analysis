n index="28" value="41"/><column index="29" value="41"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">-- show players
SELECT *
FROM players

-- Top 10 scores
SELECT NAME, TEAM, PPG
FROM Players
ORDER BY PPG DESC
LIMIT 10;

-- Top 10 rebounders
SELECT NAME, TEAM, RPG
FROM Players
ORDER BY RPG DESC
LIMIT 10;

-- Assist Leaders
SELECT NAME, TEAM, APG
FROM Players
Order BY APG DESC
LIMIT 10;

-- Highest Scoring Teams (by players)
SELECT  TEAM, avg(PPG)
FROM Players
Group BY TEAM
Order BY avg(ppg) DESC
LIMIT 10;

-- Best True Shooting %
SELECT NAME, TEAM, &quot;TS%&quot;
FROM Players
ORDER BY &quot;TS%&quot; DESC
LIMIT 10;

-- Show players who score more than 20 points per game
SELECT NAME, TEAM, PPG
FROM Players
WHERE PPG &gt; 20
ORDER BY PPG DESC;

-- Find teams with high scoring averages per player
SELECT TEAM, AVG(PPG) AS avg_team_points
FROM Players
GROUP BY TEAM
HAVING AVG(PPG) &gt; 7.5
ORDER BY avg_team_points DESC;

-- Categorize players by scoring level
SELECT NAME, TEAM, PPG,
CASE
    WHEN PPG &gt;= 25 THEN 'Elite Scorer'
    WHEN PPG &gt;= 15 THEN 'Good Scorer'
    ELSE 'Low Scorer'
END AS Scoring_Level
FROM Players
ORDER BY PPG DESC;

-- Find scoring tiers for players averaging over 10 PPG
SELECT NAME, TEAM, PPG,
CASE
    WHEN PPG &gt;= 25 THEN 'Star'
    WHEN PPG &gt;= 18 THEN 'Starter'
    ELSE 'Role Player'
END AS Player_Tier
FROM Players
WHERE PPG &gt; 10
ORDER BY PPG DESC;

-- Find the highest scoring player from each team
SELECT TEAM, NAME, PPG
FROM Players
WHERE PPG = (
    SELECT MAX(PPG)
    FROM Players p2
    WHERE p2.TEAM = Players.TEAM
)
ORDER BY PPG DESC;

-- All around players
SELECT NAME, TEAM, PPG, RPG, APG
FROM Players
WHERE PPG &gt;= 20
AND RPG &gt;= 5
AND APG &gt;= 5
ORDER BY PPG DESC;

-- Average points by position
SELECT POS, AVG(PPG) AS avg_points
FROM Players
GROUP BY POS
ORDER BY avg_points DESC;

-- Underrated players
SELECT NAME, TEAM, PPG, RPG, APG,  RANK
FROM Players
WHERE PPG &gt;=8
AND RPG &gt;= 3
AND APG &gt;= 3
AND RANK &gt; 40
ORDER BY PPG DESC;

-- Top 5 players by each position
SELECT *
FROM (
    SELECT POS, NAME, TEAM, PPG,
           RANK() OVER (PARTITION BY POS ORDER BY PPG DESC) AS position_rank
    FROM Players
)
WHERE position_rank &lt;= 5
ORDER BY POS, position_rank;</sql><current_tab id="0"/></tab_sql></sqlb_project>
